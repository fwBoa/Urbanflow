# ─── Urban Flow Mobility — environnement production (MODÈLE) ───
# 1. Copier ce modèle vers docker/.env sur le VPS.
# 2. Remplacer TOUS les placeholders ci-dessous par les secrets générés.
# 3. Ne JAMAIS commiter docker/.env dans le dépôt.
# 4. Ne JAMAIS commiter ce modèle avec des secrets réels.

# ─── Général ───
NODE_ENV=production

# ─── Base de données ───
POSTGRES_USER=urbanflow
POSTGRES_PASSWORD=__POSTGRES_PASSWORD__
POSTGRES_DB=urbanflow
# Le backend contacte le conteneur postgres via le réseau Docker interne :
DATABASE_URL=postgresql://urbanflow:__POSTGRES_PASSWORD__@postgres:5432/urbanflow

# ─── Backend (NestJS) ───
BACKEND_PORT=4000
# Chaîne aléatoire forte, 64+ caractères. Le déploiement bloque si c'est la valeur par défaut.
JWT_SECRET=__JWT_SECRET__
JWT_EXPIRATION=2h
COOKIE_SECRET=__COOKIE_SECRET__
# Origines autorisées pour CORS, séparées par des virgules.
CORS_ORIGIN=https://urbanflow-mobility.fr,https://www.urbanflow-mobility.fr

# ─── Frontend (Next.js) ───
# Laisser vide en production : les URLs API relatives "/api" sont proxifiées par Nginx.
NEXT_PUBLIC_API_URL=

# ─── Web Push VAPID ───
# Générer une paire : npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=__VAPID_PUBLIC_KEY__
VAPID_PUBLIC_KEY=__VAPID_PUBLIC_KEY__
VAPID_PRIVATE_KEY=__VAPID_PRIVATE_KEY__
VAPID_SUBJECT=mailto:contact@urbanflow-mobility.fr

# ─── Transport (PRIM — Île-de-France Mobilités) ───
# Inscription gratuite : https://prim.iledefrance-mobilites.fr/
PRIM_API_URL=https://prim.iledefrance-mobilites.fr
PRIM_API_KEY=__PRIM_API_KEY__
IDFM_DATA_API_URL=https://data.iledefrance-mobilites.fr/api/explore/v2.1

# ─── Transport (GTFS — URLs de téléchargement) ───
GTFS_STATIC_URL=https://prim.iledefrance-mobilites.fr/v1/gtfs/static/download
GTFS_RT_URL=https://prim.iledefrance-mobilites.fr/gtfs-rt/v1

# Rayon autour de Paris pour le chargement GTFS statique (km).
GTFS_RADIUS_KM=10

# ─── Carte ───
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
NEXT_PUBLIC_MAP_ATTRIBUTION=© OpenStreetMap contributors

# ─── Admin par défaut ───
ADMIN_EMAIL=admin@urbanflow.app
ADMIN_PASSWORD=admin123

# ─── Logs Docker (rotation) ───
LOG_MAX_SIZE=10m
LOG_MAX_FILE=5
