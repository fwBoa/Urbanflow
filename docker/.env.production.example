# ─── Urban Flow Mobility — environnement production (exemple) ───
# 1. Copier ce fichier vers docker/.env et remplir les valeurs réelles.
# 2. Ne JAMAIS commiter docker/.env dans le dépôt.
# 3. Utiliser des secrets forts et des certificats TLS réels.

# ─── Général ───
NODE_ENV=production

# ─── Base de données ───
POSTGRES_USER=urbanflow
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_RANDOM_PASSWORD
POSTGRES_DB=urbanflow
# Le backend contacte le conteneur postgres via le réseau Docker interne :
DATABASE_URL=postgresql://urbanflow:CHANGE_ME_TO_A_STRONG_RANDOM_PASSWORD@postgres:5432/urbanflow

# ─── Backend (NestJS) ───
BACKEND_PORT=4000
# Chaîne aléatoire forte, 64+ caractères. Le déploiement bloque si c'est la valeur par défaut.
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_EXPIRATION=2h
# Origines autorisées pour CORS, séparées par des virgules.
CORS_ORIGIN=https://urbanflow.app,https://www.urbanflow.app

# ─── Frontend (Next.js) ───
# Laisser vide en production : les URLs API relatives "/api" sont proxifiées par Nginx.
NEXT_PUBLIC_API_URL=

# ─── Web Push VAPID ───
# Générer une paire : npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=REPLACE_WITH_YOUR_VAPID_PUBLIC_KEY
VAPID_PUBLIC_KEY=REPLACE_WITH_YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=REPLACE_WITH_YOUR_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:contact@urbanflow.app

# ─── Transport (PRIM — Île-de-France Mobilités) ───
# Inscription gratuite : https://prim.iledefrance-mobilites.fr/
PRIM_API_URL=https://prim.iledefrance-mobilites.fr
PRIM_API_KEY=REPLACE_WITH_YOUR_PRIM_API_KEY
IDFM_DATA_API_URL=https://data.iledefrance-mobilites.fr/api/explore/v2.1

# ─── Transport (GTFS — URLs de téléchargement) ───
GTFS_STATIC_URL=https://prim.iledefrance-mobilites.fr/v1/gtfs/static/download
GTFS_RT_URL=https://prim.iledefrance-mobilites.fr/gtfs-rt/v1

# Rayon autour de Paris pour le chargement GTFS statique (km).
# Plus la valeur est grande, plus la base est volumineuse.
GTFS_RADIUS_KM=10

# ─── Carte ───
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
NEXT_PUBLIC_MAP_ATTRIBUTION=© OpenStreetMap contributors

# ─── Logs Docker (rotation) ───
# LOG_MAX_SIZE=10m
# LOG_MAX_FILE=5
