# ─── Urban Flow Mobility ───
# Variables d'environnement par défaut (ne pas commettre les secrets en production)

# ─── Général ───
NODE_ENV=development

# ─── Base de données ───
POSTGRES_USER=urbanflow
POSTGRES_PASSWORD=urbanflow_dev
POSTGRES_DB=urbanflow
DATABASE_URL=postgresql://urbanflow:urbanflow_dev@localhost:5432/urbanflow

# ─── Backend (NestJS) ───
BACKEND_PORT=4000
# OWASP §5.5: JWT secret must be changed in production
JWT_SECRET=change_me_in_production
# OWASP §5.5: JWT expiry reduced from 24h to 2h
JWT_EXPIRATION=2h
# CORS: comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3001

# ─── Frontend (Next.js) ───
NEXT_PUBLIC_API_URL=http://localhost:4000
# Web Push VAPID (public key only, used by the browser to subscribe)
# Générer une paire : npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# ─── Web Push (backend VAPID) ───
# Générer une paire : npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:contact@urbanflow.app

# ─── Transport (PRIM — Île-de-France Mobilités) ───
# Inscription gratuite : https://prim.iledefrance-mobilites.fr/
# NB : l'ancien host api-lab.idfm.fr est décommissionné (DNS SERVFAIL).
# Utiliser prim.iledefrance-mobilites.fr — la clé API PRIM y est valable.
PRIM_API_URL=https://prim.iledefrance-mobilites.fr
PRIM_API_KEY=your_prim_api_key_here
IDFM_DATA_API_URL=https://data.iledefrance-mobilites.fr/api/explore/v2.1

# ─── Transport (GTFS — URLs de téléchargement) ───
# NB : variables legacy, non lues par le code (le parser GTFS utilise des
# sources codées en dur : opendatasoft + prim.iledefrance-mobilites.fr/v1/gtfs/static/download).
GTFS_STATIC_URL=https://prim.iledefrance-mobilites.fr/v1/gtfs/static/download
GTFS_RT_URL=https://prim.iledefrance-mobilites.fr/gtfs-rt/v1

# ─── Carte ───
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
NEXT_PUBLIC_MAP_ATTRIBUTION=© OpenStreetMap contributors