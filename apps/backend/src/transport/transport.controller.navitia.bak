import {
  Controller,
  Get,
  Query,
  Param,
  ParseFloatPipe,
  HttpException,
  HttpStatus,
} from '@nestjs/common';
import { NavitiaService } from './navitia.service';

/**
 * Contrôleur Transport — Expose les endpoints de l'API Navitia
 * au frontend UrbanFlow via des routes REST propres.
 *
 * Routes disponibles :
 * - GET /api/transport/health          → Vérification de la connexion Navitia
 * - GET /api/transport/journeys         → Recherche d'itinéraires
 * - GET /api/transport/places           → Autocomplétion de lieux
 * - GET /api/transport/pt-objects       → Recherche d'objets transport
 * - GET /api/transport/nearby           → Arrêts à proximité
 * - GET /api/transport/departures/:id   → Prochains départs d'un arrêt
 * - GET /api/transport/traffic           → Perturbations en temps réel
 * - GET /api/transport/lines             → Liste des lignes
 * - GET /api/transport/modes             → Modes de transport
 * - GET /api/transport/networks          → Réseaux de transport
 * - GET /api/transport/isochrones       → Isochrones
 * - GET /api/transport/reverse-geocode   → Géocodage inversé
 * - GET /api/transport/stop-schedules/:id → Horaires d'un arrêt
 */
@Controller('transport')
export class TransportController {
  constructor(private readonly navitiaService: NavitiaService) {}

  // ─── Santé ────────────────────────────────────────────────────────────

  @Get('health')
  async healthCheck() {
    return this.navitiaService.healthCheck();
  }

  // ─── Itinéraires (F2) ────────────────────────────────────────────────

  @Get('journeys')
  async searchJourneys(
    @Query('from') from: string,
    @Query('to') to: string,
    @Query('datetime') datetime?: string,
    @Query('datetime_represents') datetimeRepresents?: 'departure' | 'arrival',
    @Query('data_freshness') dataFreshness?: 'base_schedule' | 'realtime',
    @Query('traveler_type') travelerType?: 'standard' | 'slow_walker' | 'fast_walker' | 'luggage' | 'wheelchair',
    @Query('max_nb_transfers') maxNbTransfers?: string,
    @Query('count') count?: string,
  ) {
    if (!from || !to) {
      throw new HttpException(
        'Parameters "from" and "to" are required (format: "lon;lat" or stop_area id)',
        HttpStatus.BAD_REQUEST,
      );
    }

    return this.navitiaService.searchJourneys({
      from,
      to,
      datetime,
      datetime_represents: datetimeRepresents,
      data_freshness: dataFreshness,
      traveler_type: travelerType,
      max_nb_transfers: maxNbTransfers ? parseInt(maxNbTransfers, 10) : undefined,
      count: count ? parseInt(count, 10) : undefined,
    });
  }

  // ─── Autocomplétion (F1) ────────────────────────────────────────────

  @Get('places')
  async searchPlaces(
    @Query('q') q: string,
    @Query('type') type?: string | string[],
    @Query('disable_geojson') disableGeojson?: string,
    @Query('depth') depth?: string,
    @Query('from') from?: string,
  ) {
    if (!q) {
      throw new HttpException(
        'Parameter "q" is required for place search',
        HttpStatus.BAD_REQUEST,
      );
    }

    const types = type
      ? Array.isArray(type)
        ? type
        : [type]
      : undefined;

    return this.navitiaService.searchPlaces({
      q,
      type: types as string[] | undefined,
      disable_geojson: disableGeojson === 'true',
      depth: depth ? parseInt(depth, 10) : undefined,
      from,
    });
  }

  @Get('pt-objects')
  async searchPtObjects(
    @Query('q') q: string,
    @Query('type') type?: string | string[],
    @Query('depth') depth?: string,
  ) {
    if (!q) {
      throw new HttpException(
        'Parameter "q" is required for PT object search',
        HttpStatus.BAD_REQUEST,
      );
    }

    const types = type
      ? Array.isArray(type)
        ? type
        : [type]
      : undefined;

    return this.navitiaService.searchPtObjects({
      q,
      type: types as string[] | undefined,
      depth: depth ? parseInt(depth, 10) : undefined,
    });
  }

  // ─── Arrêts à proximité (F1, F3) ─────────────────────────────────────

  @Get('nearby')
  async getPlacesNearby(
    @Query('lon', ParseFloatPipe) lon: number,
    @Query('lat', ParseFloatPipe) lat: number,
    @Query('distance') distance?: string,
    @Query('type') type?: string | string[],
    @Query('count') count?: string,
  ) {
    const types = type
      ? Array.isArray(type)
        ? type
        : [type]
      : undefined;

    return this.navitiaService.getPlacesNearby({
      lon,
      lat,
      distance: distance ? parseInt(distance, 10) : undefined,
      type: types as string[] | undefined,
      count: count ? parseInt(count, 10) : undefined,
    });
  }

  // ─── Prochains départs (F1) ─────────────────────────────────────────

  @Get('departures/:id')
  async getNextDepartures(
    @Param('id') stopAreaId: string,
    @Query('from_datetime') fromDatetime?: string,
    @Query('duration') duration?: string,
    @Query('count') count?: string,
    @Query('data_freshness') dataFreshness?: 'base_schedule' | 'realtime',
  ) {
    return this.navitiaService.getNextDepartures({
      stopAreaId,
      from_datetime: fromDatetime,
      duration: duration ? parseInt(duration, 10) : undefined,
      count: count ? parseInt(count, 10) : undefined,
      data_freshness: dataFreshness,
    });
  }

  // ─── Perturbations (F1) ──────────────────────────────────────────────

  @Get('traffic')
  async getTrafficReports(
    @Query('since') since?: string,
    @Query('until') until?: string,
  ) {
    return this.navitiaService.getTrafficReports({
      since,
      until,
    });
  }

  @Get('line-reports')
  async getLineReports(
    @Query('since') since?: string,
    @Query('until') until?: string,
  ) {
    return this.navitiaService.getLineReports({
      since,
      until,
    });
  }

  // ─── Exploration du réseau (F1) ──────────────────────────────────────

  @Get('lines')
  async getLines(
    @Query('count') count?: string,
    @Query('depth') depth?: string,
    @Query('start_page') startPage?: string,
    @Query('disable_geojson') disableGeojson?: string,
  ) {
    return this.navitiaService.getLines({
      count: count ? parseInt(count, 10) : undefined,
      depth: depth ? parseInt(depth, 10) : undefined,
      start_page: startPage ? parseInt(startPage, 10) : undefined,
      disable_geojson: disableGeojson === 'true',
    });
  }

  @Get('modes')
  async getPhysicalModes() {
    return this.navitiaService.getPhysicalModes();
  }

  @Get('networks')
  async getNetworks(
    @Query('count') count?: string,
    @Query('depth') depth?: string,
  ) {
    return this.navitiaService.getNetworks({
      count: count ? parseInt(count, 10) : undefined,
      depth: depth ? parseInt(depth, 10) : undefined,
    });
  }

  // ─── Isochrones (F2 avancé) ──────────────────────────────────────────

  @Get('isochrones')
  async getIsochrones(
    @Query('from') from: string,
    @Query('boundary_duration') boundaryDuration?: string | string[],
    @Query('datetime') datetime?: string,
    @Query('min_duration') minDuration?: string,
    @Query('max_duration') maxDuration?: string,
  ) {
    if (!from) {
      throw new HttpException(
        'Parameter "from" is required (format: "lon;lat" or stop_area id)',
        HttpStatus.BAD_REQUEST,
      );
    }

    const durations = boundaryDuration
      ? Array.isArray(boundaryDuration)
        ? boundaryDuration.map((d) => parseInt(d, 10))
        : [parseInt(boundaryDuration, 10)]
      : undefined;

    return this.navitiaService.getIsochrones({
      from,
      boundary_duration: durations,
      datetime,
      min_duration: minDuration ? parseInt(minDuration, 10) : undefined,
      max_duration: maxDuration ? parseInt(maxDuration, 10) : undefined,
    });
  }

  // ─── Géocodage inversé ────────────────────────────────────────────────

  @Get('reverse-geocode')
  async reverseGeocode(
    @Query('lon', ParseFloatPipe) lon: number,
    @Query('lat', ParseFloatPipe) lat: number,
  ) {
    return this.navitiaService.reverseGeocode(lon, lat);
  }

  // ─── Horaires d'arrêts ───────────────────────────────────────────────

  @Get('stop-schedules/:id')
  async getStopSchedules(
    @Param('id') stopAreaId: string,
    @Query('from_datetime') fromDatetime?: string,
    @Query('duration') duration?: string,
    @Query('data_freshness') dataFreshness?: 'base_schedule' | 'realtime',
  ) {
    return this.navitiaService.getStopSchedules({
      stopAreaId,
      from_datetime: fromDatetime,
      duration: duration ? parseInt(duration, 10) : undefined,
      data_freshness: dataFreshness,
    });
  }
}