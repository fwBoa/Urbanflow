import { Injectable, Logger } from '@nestjs/common';
import { ConfigService } from '@nestjs/config';
import { HttpService } from '@nestjs/axios';
import { firstValueFrom } from 'rxjs';
import { AxiosRequestConfig } from 'axios';

/**
 * Service d'intégration avec l'API Navitia (France Mobilité / Keolis / Hove)
 * Coverage Île-de-France : fr-idf
 *
 * Endpoints principaux utilisés :
 * - /coverage/{coverage}/journeys      → Calcul d'itinéraires multimodaux
 * - /coverage/{coverage}/places         → Autocomplétion de lieux
 * - /coverage/{coverage}/coords/{lon;lat}/places_nearby → Arrêts à proximité
 * - /coverage/{coverage}/stop_areas/{id}/departures → Prochains départs
 * - /coverage/{coverage}/traffic_reports → Perturbations en temps réel
 * - /coverage/{coverage}/lines           → Liste des lignes
 * - /coverage/{coverage}/physical_modes  → Modes de transport
 * - /coverage/{coverage}/isochrones      → Isochrones (zones accessibles)
 */
@Injectable()
export class NavitiaService {
  private readonly logger = new Logger(NavitiaService.name);
  private readonly apiUrl: string;
  private readonly token: string;
  private readonly coverage: string;

  constructor(
    private readonly httpService: HttpService,
    private readonly configService: ConfigService,
  ) {
    this.apiUrl = this.configService.get<string>('NAVITIA_API_URL', 'https://api.navitia.io/v1');
    this.token = this.configService.get<string>('NAVITIA_TOKEN', '');
    this.coverage = this.configService.get<string>('NAVITIA_COVERAGE', 'fr-idf');

    if (!this.token) {
      this.logger.warn('NAVITIA_TOKEN is not set. API calls will fail. Get your token at https://navitia.io/');
    }
  }

  /**
   * Effectue un appel authentifié à l'API Navitia
   */
  private async callNavitia(endpoint: string, params: Record<string, string> = {}): Promise<any> {
    const url = `${this.apiUrl}${endpoint}`;
    const config: AxiosRequestConfig = {
      headers: {
        Authorization: this.token,
      },
      params,
    };

    try {
      const response = await firstValueFrom(
        this.httpService.get(url, config),
      );
      return response.data;
    } catch (error) {
      this.logger.error(`Navitia API error: ${error.message}`, error.stack);
      throw error;
    }
  }

  // ─── Itinéraires (F2) ───────────────────────────────────────────────

  /**
   * Recherche d'itinéraires multimodaux entre deux points
   * Endpoint: /coverage/{coverage}/journeys
   */
  async searchJourneys(params: {
    from: string; // "lon;lat" ou stop_area id
    to: string;   // "lon;lat" ou stop_area id
    datetime?: string; // YYYYMMDDThhmmss
    datetime_represents?: 'departure' | 'arrival';
    data_freshness?: 'base_schedule' | 'realtime';
    forbidden_uris?: string[];
    allowed_id?: string[];
    first_section_mode?: string[];
    last_section_mode?: string[];
    traveler_type?: 'standard' | 'slow_walker' | 'fast_walker' | 'luggage' | 'wheelchair';
    max_nb_transfers?: number;
    min_nb_transfers?: number;
    count?: number;
  }): Promise<any> {
    const queryParams: Record<string, string> = {
      from: params.from,
      to: params.to,
    };

    if (params.datetime) queryParams.datetime = params.datetime;
    if (params.datetime_represents) queryParams.datetime_represents = params.datetime_represents;
    if (params.data_freshness) queryParams.data_freshness = params.data_freshness;
    if (params.traveler_type) queryParams.traveler_type = params.traveler_type;
    if (params.max_nb_transfers !== undefined) queryParams.max_nb_transfers = String(params.max_nb_transfers);
    if (params.min_nb_transfers !== undefined) queryParams.min_nb_transfers = String(params.min_nb_transfers);
    if (params.count) queryParams.count = String(params.count);

    // Array params
    if (params.forbidden_uris) {
      params.forbidden_uris.forEach((uri, i) => {
        queryParams[`forbidden_uris[${i}]`] = uri;
      });
    }
    if (params.allowed_id) {
      params.allowed_id.forEach((id, i) => {
        queryParams[`allowed_id[${i}]`] = id;
      });
    }
    if (params.first_section_mode) {
      params.first_section_mode.forEach((mode, i) => {
        queryParams[`first_section_mode[${i}]`] = mode;
      });
    }
    if (params.last_section_mode) {
      params.last_section_mode.forEach((mode, i) => {
        queryParams[`last_section_mode[${i}]`] = mode;
      });
    }

    return this.callNavitia(`/coverage/${this.coverage}/journeys`, queryParams);
  }

  // ─── Autocomplétion (F1) ────────────────────────────────────────────

  /**
   * Recherche de lieux (arrêts, adresses, POI) par autocomplétion
   * Endpoint: /coverage/{coverage}/places
   */
  async searchPlaces(params: {
    q: string;
    type?: string[]; // stop_area, address, poi, administrative_region
    disable_geojson?: boolean;
    depth?: number;
    from?: string; // lon;lat pour prioriser les résultats proches
  }): Promise<any> {
    const queryParams: Record<string, string> = {
      q: params.q,
    };

    if (params.disable_geojson !== undefined) queryParams.disable_geojson = String(params.disable_geojson);
    if (params.depth !== undefined) queryParams.depth = String(params.depth);
    if (params.from) queryParams.from = params.from;

    if (params.type) {
      params.type.forEach((t, i) => {
        queryParams[`type[${i}]`] = t;
      });
    }

    return this.callNavitia(`/coverage/${this.coverage}/places`, queryParams);
  }

  /**
   * Recherche d'objets transport en commun par autocomplétion
   * Endpoint: /coverage/{coverage}/pt_objects
   */
  async searchPtObjects(params: {
    q: string;
    type?: string[]; // network, commercial_mode, line, route, stop_area, stop_point
    depth?: number;
    disable_disruption?: boolean;
  }): Promise<any> {
    const queryParams: Record<string, string> = {
      q: params.q,
    };

    if (params.depth !== undefined) queryParams.depth = String(params.depth);
    if (params.disable_disruption !== undefined) queryParams.disable_disruption = String(params.disable_disruption);

    if (params.type) {
      params.type.forEach((t, i) => {
        queryParams[`type[${i}]`] = t;
      });
    }

    return this.callNavitia(`/coverage/${this.coverage}/pt_objects`, queryParams);
  }

  // ─── Arrêts à proximité (F1, F3) ────────────────────────────────────

  /**
   * Recherche d'arrêts et lieux à proximité de coordonnées
   * Endpoint: /coverage/{coverage}/coords/{lon;lat}/places_nearby
   */
  async getPlacesNearby(params: {
    lon: number;
    lat: number;
    distance?: number; // en mètres, défaut 500
    type?: string[]; // stop_area, stop_point, poi
    count?: number;
    depth?: number;
  }): Promise<any> {
    const queryParams: Record<string, string> = {};

    if (params.distance) queryParams.distance = String(params.distance);
    if (params.count) queryParams.count = String(params.count);
    if (params.depth) queryParams.depth = String(params.depth);

    if (params.type) {
      params.type.forEach((t, i) => {
        queryParams[`type[${i}]`] = t;
      });
    }

    return this.callNavitia(
      `/coverage/${this.coverage}/coords/${params.lon};${params.lat}/places_nearby`,
      queryParams,
    );
  }

  // ─── Prochains départs (F1) ─────────────────────────────────────────

  /**
   * Prochains départs depuis un arrêt
   * Endpoint: /coverage/{coverage}/stop_areas/{id}/departures
   */
  async getNextDepartures(params: {
    stopAreaId: string;
    from_datetime?: string; // YYYYMMDDThhmmss
    duration?: number; // en secondes
    count?: number;
    data_freshness?: 'base_schedule' | 'realtime';
    depth?: number;
  }): Promise<any> {
    const queryParams: Record<string, string> = {};

    if (params.from_datetime) queryParams.from_datetime = params.from_datetime;
    if (params.duration) queryParams.duration = String(params.duration);
    if (params.count) queryParams.count = String(params.count);
    if (params.data_freshness) queryParams.data_freshness = params.data_freshness;
    if (params.depth) queryParams.depth = String(params.depth);

    return this.callNavitia(
      `/coverage/${this.coverage}/stop_areas/${encodeURIComponent(params.stopAreaId)}/departures`,
      queryParams,
    );
  }

  // ─── Perturbations en temps réel (F1) ────────────────────────────────

  /**
   * Rapports de trafic (perturbations) pour la couverture
   * Endpoint: /coverage/{coverage}/traffic_reports
   */
  async getTrafficReports(params?: {
    since?: string;
    until?: string;
    count?: number;
    depth?: number;
  }): Promise<any> {
    const queryParams: Record<string, string> = {};

    if (params?.since) queryParams.since = params.since;
    if (params?.until) queryParams.until = params.until;
    if (params?.count) queryParams.count = String(params.count);
    if (params?.depth) queryParams.depth = String(params.depth);

    return this.callNavitia(`/coverage/${this.coverage}/traffic_reports`, queryParams);
  }

  /**
   * Rapports de perturbations par ligne
   * Endpoint: /coverage/{coverage}/line_reports
   */
  async getLineReports(params?: {
    since?: string;
    until?: string;
    count?: number;
    depth?: number;
  }): Promise<any> {
    const queryParams: Record<string, string> = {};

    if (params?.since) queryParams.since = params.since;
    if (params?.until) queryParams.until = params.until;
    if (params?.count) queryParams.count = String(params.count);
    if (params?.depth) queryParams.depth = String(params.depth);

    return this.callNavitia(`/coverage/${this.coverage}/line_reports`, queryParams);
  }

  // ─── Exploration du réseau (F1) ─────────────────────────────────────

  /**
   * Liste des lignes de la couverture
   * Endpoint: /coverage/{coverage}/lines
   */
  async getLines(params?: {
    count?: number;
    depth?: number;
    start_page?: number;
    disable_geojson?: boolean;
  }): Promise<any> {
    const queryParams: Record<string, string> = {};

    if (params?.count) queryParams.count = String(params.count);
    if (params?.depth) queryParams.depth = String(params.depth);
    if (params?.start_page !== undefined) queryParams.start_page = String(params.start_page);
    if (params?.disable_geojson !== undefined) queryParams.disable_geojson = String(params.disable_geojson);

    return this.callNavitia(`/coverage/${this.coverage}/lines`, queryParams);
  }

  /**
   * Liste des modes de transport physiques
   * Endpoint: /coverage/{coverage}/physical_modes
   */
  async getPhysicalModes(): Promise<any> {
    return this.callNavitia(`/coverage/${this.coverage}/physical_modes`);
  }

  /**
   * Liste des réseaux de transport
   * Endpoint: /coverage/{coverage}/networks
   */
  async getNetworks(params?: {
    count?: number;
    depth?: number;
  }): Promise<any> {
    const queryParams: Record<string, string> = {};

    if (params?.count) queryParams.count = String(params.count);
    if (params?.depth) queryParams.depth = String(params.depth);

    return this.callNavitia(`/coverage/${this.coverage}/networks`, queryParams);
  }

  // ─── Isochrones (F2 avancé) ─────────────────────────────────────────

  /**
   * Calcul d'isochrones (zones accessibles en un temps donné)
   * Endpoint: /coverage/{coverage}/isochrones
   */
  async getIsochrones(params: {
    from: string; // "lon;lat" ou stop_area id
    boundary_duration?: number[]; // en secondes, ex: [600, 1200, 1800]
    datetime?: string;
    min_duration?: number;
    max_duration?: number;
    forbidden_uris?: string[];
    first_section_mode?: string[];
    last_section_mode?: string[];
  }): Promise<any> {
    const queryParams: Record<string, string> = {
      from: params.from,
    };

    if (params.datetime) queryParams.datetime = params.datetime;
    if (params.min_duration !== undefined) queryParams.min_duration = String(params.min_duration);
    if (params.max_duration !== undefined) queryParams.max_duration = String(params.max_duration);

    if (params.boundary_duration) {
      params.boundary_duration.forEach((d, i) => {
        queryParams[`boundary_duration[${i}]`] = String(d);
      });
    }
    if (params.forbidden_uris) {
      params.forbidden_uris.forEach((uri, i) => {
        queryParams[`forbidden_uris[${i}]`] = uri;
      });
    }
    if (params.first_section_mode) {
      params.first_section_mode.forEach((mode, i) => {
        queryParams[`first_section_mode[${i}]`] = mode;
      });
    }
    if (params.last_section_mode) {
      params.last_section_mode.forEach((mode, i) => {
        queryParams[`last_section_mode[${i}]`] = mode;
      });
    }

    return this.callNavitia(`/coverage/${this.coverage}/isochrones`, queryParams);
  }

  // ─── Géocodage inversé ───────────────────────────────────────────────

  /**
   * Géocodage inversé : coordonnées → adresse
   * Endpoint: /coords/{lon;lat}
   */
  async reverseGeocode(lon: number, lat: number): Promise<any> {
    return this.callNavitia(`/coords/${lon};${lat}`);
  }

  // ─── Horaires d'arrêts ───────────────────────────────────────────────

  /**
   * Horaires de passage à un arrêt (groupés par route)
   * Endpoint: /coverage/{coverage}/stop_areas/{id}/stop_schedules
   */
  async getStopSchedules(params: {
    stopAreaId: string;
    from_datetime?: string;
    duration?: number;
    count?: number;
    data_freshness?: 'base_schedule' | 'realtime';
    depth?: number;
  }): Promise<any> {
    const queryParams: Record<string, string> = {};

    if (params.from_datetime) queryParams.from_datetime = params.from_datetime;
    if (params.duration) queryParams.duration = String(params.duration);
    if (params.count) queryParams.count = String(params.count);
    if (params.data_freshness) queryParams.data_freshness = params.data_freshness;
    if (params.depth) queryParams.depth = String(params.depth);

    return this.callNavitia(
      `/coverage/${this.coverage}/stop_areas/${encodeURIComponent(params.stopAreaId)}/stop_schedules`,
      queryParams,
    );
  }

  // ─── Santé du service ────────────────────────────────────────────────

  /**
   * Vérifie que l'API Navitia est accessible et que le token est valide
   */
  async healthCheck(): Promise<{ status: string; coverage: string }> {
    try {
      const data = await this.callNavitia(`/coverage/${this.coverage}`);
      return {
        status: 'ok',
        coverage: data?.regions?.[0]?.id || this.coverage,
      };
    } catch (error) {
      return {
        status: 'error',
        coverage: this.coverage,
      };
    }
  }
}